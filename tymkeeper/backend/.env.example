# TymKeeper — Environment Variables
# Copy this to .env and fill in your values

# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── PostgreSQL Database ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tymkeeper
DB_USER=postgres
DB_PASSWORD=your_password_here

# Optional: Use a full connection string instead
# DATABASE_URL=postgresql://postgres:password@localhost:5432/tymkeeper

# ─── JWT ───
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ───
# Comma-separated list of allowed origins
FRONTEND_URL=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
